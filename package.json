{
  "name": "keru",
  "version": "0.1.0",
  "description": "Keru MVP backend - modular monolith (residual IDesign architecture)",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/keru-api/apps/keru-api/src/main.js",
    "openapi": "GENERATE_OPENAPI=true npm run start",
    "seed": "ts-node -r tsconfig-paths/register apps/keru-api/src/seed.ts",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:e2e": "jest --config ./apps/keru-api/test/jest-e2e.json",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "app:up": "docker compose --profile app up -d --build",
    "app:down": "docker compose --profile app down"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/typeorm": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@keru/core(|/.*)$": "<rootDir>/libs/core/src/$1",
      "^@keru/membership(|/.*)$": "<rootDir>/libs/membership/src/$1",
      "^@keru/hiring(|/.*)$": "<rootDir>/libs/hiring/src/$1",
      "^@keru/care-record(|/.*)$": "<rootDir>/libs/care-record/src/$1",
      "^@keru/care-consult(|/.*)$": "<rootDir>/libs/care-consult/src/$1",
      "^@keru/reputation(|/.*)$": "<rootDir>/libs/reputation/src/$1"
    }
  }
}
