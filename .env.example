# App
PORT=3000
NODE_ENV=development

# PostgreSQL (partición marketplace + clínica; en el MVP una sola instancia, dos schemas)
DB_HOST=localhost
DB_PORT=5432
DB_USER=keru
DB_PASSWORD=keru
DB_NAME=keru
# Sincronización de esquema (solo dev; en prod usar migraciones)
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis (BullMQ - outbox dispatcher)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth (UC-04) - JWT
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES=7d

# AWS (floci en dev — emulador local estilo LocalStack; en prod, roles IAM sin claves)
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
SES_FROM=no-reply@keru.app
S3_BUCKET=keru-media
# URL publica de las imagenes RELATIVA al origen de la webapp (/media -> proxy -> floci).
# Asi el previo funciona igual en localhost, https y acceso remoto (Tailscale), sin mixed content.
S3_PUBLIC_URL=/media
# URL base pública de la webapp (links de invitación en emails)
APP_BASE_URL=http://localhost:4200

# Web Push VAPID (UC-18). Par de DEV — generar el propio para prod: npx web-push generate-vapid-keys
# Sin claves el canal push queda deshabilitado y las alertas siguen solo en la campana (§2.7).
VAPID_PUBLIC_KEY=BB7iT-LtYzEkg9Il74b4bu-hKZVls6rbMKyfsoOlFHhRr1bSx9Jfnon5D4ypokrMudWNSO_u_pY9HSYvCp_kaIQ
VAPID_PRIVATE_KEY=HgvLYRBz-DgW3qFKFEf8Dd9suuQnKuRCz0qTLXaiTik
VAPID_SUBJECT=mailto:no-reply@keru.app

# Rate limiting (KER-14): login/signup por IP. Sin la env rige el default estricto (5/min);
# subirlo solo en stacks locales donde la suite E2E crea varias cuentas desde una IP.
# THROTTLE_AUTH_LIMIT=50
