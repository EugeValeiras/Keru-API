# App
PORT=3000
NODE_ENV=development

# PostgreSQL (partición marketplace + clínica; en el MVP una sola instancia, dos schemas)
DB_HOST=localhost
DB_PORT=5432
DB_USER=keru
DB_PASSWORD=keru
DB_NAME=keru
# Sincronización de esquema (solo dev; en prod usar migraciones)
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis (BullMQ - outbox dispatcher)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth (UC-04) - JWT
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES=7d

# AWS (floci en dev — emulador local estilo LocalStack; en prod, roles IAM sin claves)
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
SES_FROM=no-reply@keru.app
S3_BUCKET=keru-media
# URL publica de las imagenes RELATIVA al origen de la webapp (/media -> proxy -> floci).
# Asi el previo funciona igual en localhost, https y acceso remoto (Tailscale), sin mixed content.
S3_PUBLIC_URL=/media
# URL base pública de la webapp (links de invitación en emails)
APP_BASE_URL=http://localhost:4200
