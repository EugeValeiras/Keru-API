# App
PORT=3000
NODE_ENV=development

# PostgreSQL (partición marketplace + clínica; en el MVP una sola instancia, dos schemas)
DB_HOST=localhost
DB_PORT=5432
DB_USER=keru
DB_PASSWORD=keru
DB_NAME=keru
# KER-29 / NFR-25: el esquema lo gobiernan las migraciones versionadas (npm run migration:run).
# synchronize puede alterar/dropear columnas del store clínico en silencio: es opt-in EXPLÍCITO
# y solo para dev local descartable / e2e (la suite lo activa en apps/keru-api/test/e2e-env.ts).
DB_SYNCHRONIZE=false
# Correr migraciones pendientes al bootear la app (lo usa el compose; en dev, correrlas a mano)
DB_MIGRATIONS_RUN=false
DB_LOGGING=false

# Redis (BullMQ - outbox dispatcher)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth (UC-04) - JWT
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES=7d

# AWS (floci en dev — emulador local estilo LocalStack; en prod, roles IAM sin claves)
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
SES_FROM=no-reply@keru.app
S3_BUCKET=keru-media
# URL publica de las imagenes RELATIVA al origen de la webapp (/media -> proxy -> floci).
# Asi el previo funciona igual en localhost, https y acceso remoto (Tailscale), sin mixed content.
S3_PUBLIC_URL=/media
# URL base pública de la webapp (links de invitación en emails)
APP_BASE_URL=http://localhost:4200

# Web Push VAPID (UC-18). GENERAR EL PROPIO: npx web-push generate-vapid-keys
# y pegarlo SOLO en tu .env local (gitignoreado). NUNCA commitear claves, ni "de dev"
# (incidente GitGuardian 2026-07-22). Sin claves el canal push queda deshabilitado
# y las alertas siguen solo en la campana (constitution §2.7).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@keru.app

# Escalación de alertas críticas sin acuse (KER-34, NFR-11): minutos sin que NADIE del círculo
# lea la notificación antes de re-notificar por push. Una sola escalación por alerta; una alerta
# más nueva del mismo (paciente, métrica) supersede a la anterior y no escala (anti-T7).
ALERT_ESCALATION_MINUTES=15

# Backups del store (KER-35, NFR-25/T14; servicio "backup" del compose, profile app):
# cada cuánto se corta un pg_dump (= RPO efectivo) y cuántos dumps se retienen (poda por
# cantidad, no por edad). Restore drill: scripts/restore-drill.sh|ps1; docs/ops/backups.md.
# BACKUP_INTERVAL_SECONDS=21600
# BACKUP_KEEP=28

# Rate limiting (KER-14): login/signup por IP. Sin la env rige el default estricto (5/min);
# subirlo solo en stacks locales donde la suite E2E crea varias cuentas desde una IP.
# THROTTLE_AUTH_LIMIT=50
# Bypass total del rate limiting SOLO para entornos de test/e2e (nunca producción)
THROTTLE_SKIP=false
